{
  "name": "nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint --ext .ts,.vue --ignore-path .gitignore .",
    "lint:fix": "eslint --ext .ts,.vue --ignore-path .gitignore . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=html",
    "db:generate": "npx nuxt db generate",
    "db:migrate": "npx nuxt db migrate",
    "db:rollback": "npx nuxt db rollback",
    "db:status": "npx nuxt db status",
    "db:seed": "tsx server/tasks/seed.ts",
    "db:truncate": "tsx server/tasks/truncate.ts",
    "db:reset": "npx nuxt db reset"
  },
  "dependencies": {
    "@ai-sdk/vue": "^3.0.175",
    "@libsql/client": "^0.17.3",
    "@nuxt/ui": "^4.7.1",
    "@nuxthub/core": "0.10.7",
    "@scalar/nuxt": "0.6.27",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "jose": "^6.2.2",
    "nuxt": "^4.4.2",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.4",
    "tiptap-extension-code-block-shiki": "^1.2.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.104",
    "@nuxt/test-utils": "^4.0.2",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-emoji": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-youtube": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "@vue/language-core": "^3.2.7",
    "@vue/test-utils": "^2.4.8",
    "happy-dom": "^20.9.0",
    "playwright-core": "^1.59.1",
    "prosemirror-model": "^1.25.4",
    "scule": "^1.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
